# ── Segredo JWT (OBRIGATÓRIO) ────────────────────────────────────────────────
# Gere um segredo seguro com: openssl rand -base64 64
JWT_SECRET=coloque_aqui_um_segredo_forte_de_no_minimo_32_caracteres

# Expiração do JWT em milissegundos (padrão: 24h)
JWT_EXPIRATION_MS=86400000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Domínio(s) do frontend separados por vírgula
CORS_ALLOWED_ORIGINS=https://seu-app.vercel.app,http://localhost:5173

# ── Banco de dados (PostgreSQL — Railway ou outro) ───────────────────────────
# Ative o profile postgres no Railway: SPRING_PROFILES_ACTIVE=postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/riggingcheck
SPRING_DATASOURCE_USERNAME=riggingcheck
SPRING_DATASOURCE_PASSWORD=senha_segura_aqui
